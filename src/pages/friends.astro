---
import Layout from '../layouts/Layout.astro';
import KnobNav from '../components/KnobNav.astro';
---

<Layout title="Friends — Emma Bennett" theme="friends">
  <main class="wrap stub">
    <KnobNav active="friends" />
    <div class="stub-body">
      <h1>Still growing…</h1>
      <p>
        The plant nook is being potted. Soon you'll find song recs and a place to
        leave a message for Emma.
      </p>
    </div>
  </main>
</Layout>

<style>
  .stub {
    min-height: 100vh;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-5);
    align-items: center;
    padding-top: var(--space-6);
    padding-bottom: var(--space-6);
  }
  .stub-body {
    max-width: 30rem;
  }
  .stub-body h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--accent-bright);
  }
  .stub-body p {
    color: var(--ink-dim);
  }
  @media (max-width: 760px) {
    .stub {
      grid-template-columns: 1fr;
      justify-items: center;
      text-align: center;
    }
  }
</style>
