---
import Layout from '../layouts/Layout.astro';
import KnobNav from '../components/KnobNav.astro';
---

<Layout title="Art — Emma Bennett" theme="art">
  <main class="wrap stub">
    <KnobNav active="art" />
    <div class="stub-body">
      <h1>Hanging the gallery…</h1>
      <p>
        The wall is being measured out. Framed pieces of my art will be hung here
        soon — salon style.
      </p>
    </div>
  </main>
</Layout>

<style>
  .stub {
    min-height: 100vh;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-5);
    align-items: center;
    padding-top: var(--space-6);
    padding-bottom: var(--space-6);
  }
  .stub-body {
    max-width: 30rem;
  }
  .stub-body h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--accent);
  }
  .stub-body p {
    color: var(--ink-dim);
  }
  @media (max-width: 760px) {
    .stub {
      grid-template-columns: 1fr;
      justify-items: center;
      text-align: center;
    }
  }
</style>
